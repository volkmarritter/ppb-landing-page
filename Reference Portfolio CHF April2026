<!DOCTYPE html>

<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Referenzportfolio CHF – Renditeorientiert</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=IBM+Plex+Mono:wght@400;500&family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0f1117;
    --paper: #f7f4ef;
    --cream: #ede9e1;
    --rule: #c8bfaa;
    --accent: #1a3a5c;
    --accent2: #8b6914;
    --red: #7c2020;
    --green: #1a4a2e;
    --mono: 'IBM Plex Mono', monospace;
    --serif: 'Source Serif 4', Georgia, serif;
    --display: 'Playfair Display', Georgia, serif;
  }

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
background: var(–paper);
color: var(–ink);
font-family: var(–serif);
font-size: 14px;
line-height: 1.65;
max-width: 1100px;
margin: 0 auto;
padding: 48px 40px 80px;
}

/* ── HEADER ── */
.masthead {
border-top: 3px solid var(–ink);
border-bottom: 1px solid var(–rule);
padding: 28px 0 20px;
margin-bottom: 36px;
display: grid;
grid-template-columns: 1fr auto;
align-items: end;
gap: 24px;
}
.masthead-tag {
font-family: var(–mono);
font-size: 10px;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–accent2);
margin-bottom: 8px;
}
.masthead h1 {
font-family: var(–display);
font-size: 32px;
font-weight: 700;
line-height: 1.15;
color: var(–accent);
}
.masthead-meta {
text-align: right;
font-family: var(–mono);
font-size: 10px;
color: #666;
line-height: 1.8;
}
.meta-row { display: flex; gap: 32px; margin-top: 16px; }
.meta-pill {
background: var(–cream);
border: 1px solid var(–rule);
padding: 6px 14px;
font-family: var(–mono);
font-size: 10px;
letter-spacing: 0.08em;
text-transform: uppercase;
}
.meta-pill span { display: block; font-size: 13px; font-family: var(–serif); text-transform: none; letter-spacing: 0; font-weight: 600; color: var(–accent); margin-top: 2px; }

/* ── SECTIONS ── */
.section {
margin-bottom: 48px;
}
.section-header {
display: flex;
align-items: baseline;
gap: 14px;
margin-bottom: 18px;
padding-bottom: 8px;
border-bottom: 2px solid var(–ink);
}
.section-label {
font-family: var(–mono);
font-size: 10px;
letter-spacing: 0.18em;
text-transform: uppercase;
color: var(–accent2);
background: var(–cream);
border: 1px solid var(–rule);
padding: 3px 8px;
white-space: nowrap;
}
.section-title {
font-family: var(–display);
font-size: 20px;
font-weight: 600;
color: var(–accent);
}

/* ── TABLES ── */
.table-wrap { overflow-x: auto; }
table {
width: 100%;
border-collapse: collapse;
font-size: 12.5px;
}
thead tr {
background: var(–ink);
color: var(–paper);
}
thead th {
font-family: var(–mono);
font-size: 9.5px;
letter-spacing: 0.12em;
text-transform: uppercase;
padding: 10px 12px;
text-align: left;
font-weight: 500;
white-space: nowrap;
}
tbody tr {
border-bottom: 1px solid var(–rule);
}
tbody tr:hover { background: var(–cream); }
tbody td {
padding: 9px 12px;
vertical-align: top;
line-height: 1.45;
}
.td-num {
font-family: var(–mono);
text-align: right;
white-space: nowrap;
}
.td-center { text-align: center; }
.weight-cell {
font-family: var(–mono);
font-weight: 500;
font-size: 13px;
}
.group-eq { background: rgba(26,58,92,0.04); }
.group-fi { background: rgba(139,105,20,0.04); }
.group-alt { background: rgba(26,74,46,0.04); }
tfoot tr { border-top: 2px solid var(–ink); background: var(–cream); }
tfoot td {
padding: 9px 12px;
font-family: var(–mono);
font-size: 12px;
font-weight: 500;
}

/* chips */
.chip {
display: inline-block;
font-family: var(–mono);
font-size: 9px;
letter-spacing: 0.05em;
padding: 2px 6px;
border-radius: 2px;
text-transform: uppercase;
}
.chip-syn { background: #e8f0e8; color: #1a4a2e; border: 1px solid #b8d4b8; }
.chip-phy { background: #e8eeF8; color: #1a3a5c; border: 1px solid #b8c8e8; }
.chip-acc { background: #f0ece0; color: #6b4f10; border: 1px solid #d4c090; }
.chip-dis { background: #f5e8e8; color: #7c2020; border: 1px solid #d4a8a8; }
.chip-hedged { background: #1a3a5c; color: #fff; }
.chip-unhedged { background: #888; color: #fff; }

/* ── BULLETS ── */
.bullet-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 10px 32px;
}
.bullet-item {
display: grid;
grid-template-columns: 16px 1fr;
gap: 8px;
align-items: start;
padding: 8px 0;
border-bottom: 1px solid var(–rule);
font-size: 13px;
}
.bullet-num {
font-family: var(–mono);
font-size: 10px;
color: var(–accent2);
padding-top: 2px;
}
strong { color: var(–accent); font-weight: 600; }

/* ── CURRENCY BAR ── */
.ccy-wrap { display: flex; flex-direction: column; gap: 10px; }
.ccy-row {
display: grid;
grid-template-columns: 80px 1fr 60px 120px;
align-items: center;
gap: 12px;
font-size: 12.5px;
}
.ccy-label { font-family: var(–mono); font-weight: 500; font-size: 11px; }
.bar-track {
background: var(–cream);
border: 1px solid var(–rule);
height: 18px;
position: relative;
}
.bar-fill {
position: absolute;
left: 0; top: 0; bottom: 0;
transition: width 0.4s;
}
.bar-chf { background: #1a3a5c; }
.bar-usd { background: #7c2020; }
.bar-eur { background: #8b6914; }
.bar-jpy { background: #1a4a2e; }
.bar-em  { background: #6b3a7c; }
.ccy-pct { font-family: var(–mono); font-size: 12px; font-weight: 500; text-align: right; }
.ccy-note { font-size: 11px; color: #666; font-style: italic; }

/* ── TOP10 ── */
.top10-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
.top10-item {
display: grid;
grid-template-columns: 28px 1fr 50px;
align-items: center;
gap: 8px;
padding: 8px 10px;
background: var(–cream);
border-left: 3px solid var(–accent);
font-size: 12.5px;
}
.top10-rank { font-family: var(–mono); font-size: 10px; color: var(–accent2); }
.top10-pct { font-family: var(–mono); font-size: 12px; font-weight: 500; text-align: right; }

/* ── REBALANCING ── */
.rebal-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 16px;
}
.rebal-card {
background: var(–cream);
border: 1px solid var(–rule);
padding: 18px;
}
.rebal-card-title {
font-family: var(–mono);
font-size: 9.5px;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–accent2);
margin-bottom: 10px;
}
.rebal-card-body { font-size: 12.5px; line-height: 1.6; }

/* ── COST BOX ── */
.cost-wrap {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 24px;
}
.cost-table { width: 100%; }
.cost-table td { padding: 5px 8px; font-size: 12.5px; border-bottom: 1px solid var(–rule); }
.cost-table .td-num { font-family: var(–mono); }
.cost-summary {
background: var(–accent);
color: var(–paper);
padding: 24px;
display: flex;
flex-direction: column;
justify-content: center;
}
.cost-summary-label { font-family: var(–mono); font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.7; margin-bottom: 8px; }
.cost-summary-num { font-family: var(–display); font-size: 42px; font-weight: 700; line-height: 1; }
.cost-summary-unit { font-family: var(–mono); font-size: 11px; opacity: 0.7; margin-top: 6px; }
.cost-note { font-size: 11.5px; margin-top: 12px; opacity: 0.85; line-height: 1.5; }

/* ── DISCLAIMER ── */
.disclaimer {
margin-top: 56px;
padding: 20px 24px;
border: 1px solid var(–rule);
background: var(–cream);
font-size: 11px;
color: #555;
line-height: 1.6;
}
.disclaimer-title {
font-family: var(–mono);
font-size: 9px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–red);
margin-bottom: 8px;
}

/* ── LOOK-THROUGH ── */
.lookt-row {
display: grid;
grid-template-columns: 180px 1fr 70px;
align-items: center;
gap: 12px;
padding: 7px 0;
border-bottom: 1px solid var(–rule);
font-size: 12.5px;
}
.lookt-bar { background: var(–cream); height: 14px; position: relative; }
.lookt-fill { position: absolute; left: 0; top: 0; bottom: 0; }

@media (max-width: 700px) {
body { padding: 24px 16px 48px; }
.bullet-grid { grid-template-columns: 1fr; }
.top10-grid { grid-template-columns: 1fr; }
.rebal-grid { grid-template-columns: 1fr; }
.cost-wrap { grid-template-columns: 1fr; }
.meta-row { flex-wrap: wrap; }
.masthead { grid-template-columns: 1fr; }
}

.footnote { font-size: 11px; color: #777; font-style: italic; margin-top: 10px; line-height: 1.5; }
.divider { border: none; border-top: 1px solid var(–rule); margin: 32px 0; }
.info-box {
background: rgba(26,58,92,0.05);
border-left: 3px solid var(–accent);
padding: 12px 16px;
margin: 14px 0;
font-size: 12.5px;
line-height: 1.6;
}
</style>

</head>
<body>

<!-- MASTHEAD -->

<div class="masthead">
  <div>
    <div class="masthead-tag">Unabhängige Portfolioanalyse · CFA-Niveau · Referenzdokument</div>
    <h1>Renditeorientiertes Referenzportfolio<br>Basiswährung CHF</h1>
    <div class="meta-row">
      <div class="meta-pill">Risikoappetit<span>Hoch</span></div>
      <div class="meta-pill">Anlagehorizont<span>≥ 10 Jahre</span></div>
      <div class="meta-pill">Aktienquote<span>70 %</span></div>
      <div class="meta-pill">Positionen<span>8 ETFs</span></div>
